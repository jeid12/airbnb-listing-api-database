# Database — hosted Neon/Railway/Render PostgreSQL connection string
DATABASE_URL=

# Server
PORT=
NODE_ENV=production

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Email (Gmail App Password — Google Account → Security → App Passwords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary (cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public API URL (used in Swagger server URL and password-reset links)
API_URL=

# Redis — use REDIS_URL (full URL) OR individual parts below
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_USER=default
REDIS_PASSWORD=
REDIS_TLS=
