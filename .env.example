# Database — hosted Neon/Railway/Render PostgreSQL connection string
DATABASE_URL=

# Server
PORT=
NODE_ENV=production

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Email — Resend (resend.com → API Keys → Create API Key)
# Free tier: 3,000 emails/month, 100/day — no domain verification needed
# FROM must be: onboarding@resend.dev (or your own verified domain)
RESEND_API_KEY=
EMAIL_FROM=Airbnb <onboarding@resend.dev>

# Cloudinary (cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public API URL (used in Swagger server URL and password-reset links)
API_URL=

# Redis — use REDIS_URL (full URL) OR individual parts below
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_USER=default
REDIS_PASSWORD=
REDIS_TLS=

# AI — DeepSeek API (platform.deepseek.com)
DEEPSEEK_API_KEY=

# AI — Groq API (console.groq.com)
GROQ_API_KEY=

# Optional web search API used by some AI exercises
TIVILY_API_KEY=
