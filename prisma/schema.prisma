generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  SYSTEM
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String?
  role             Role      @default(GUEST)
  avatar           String?
  avatarPublicId   String?
  bio              String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isSuperhost      Boolean   @default(false)
  listings         Listing[]
  bookings         Booking[]
  reviews          Review[]
  profile          Profile?
  wishlists        Wishlist[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  notifications    Notification[]

  @@index([name])
  @@index([role])
}

model Profile {
  id      String  @id @default(uuid())
  bio     String?
  website String?
  country String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String  @unique
}

model Listing {
  id            String         @id @default(uuid())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  bedrooms      Int            @default(1)
  beds          Int            @default(1)
  bathrooms     Float          @default(1)
  type          ListingType
  category      String         @default("trending")
  amenities     String[]
  rating        Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  host          User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  hostId        String
  bookings      Booking[]
  photos        ListingPhoto[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([location])
  @@index([type])
  @@index([category])
  @@index([pricePerNight])
  @@index([hostId])
}

model ListingPhoto {
  id        String  @id @default(uuid())
  url       String
  publicId  String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
}

model Booking {
  id         String        @id @default(uuid())
  checkIn    DateTime
  checkOut   DateTime
  guests     Int           @default(1)
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  guestId    String
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId  String
  review     Review?

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?  @unique
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

model Wishlist {
  id        String         @id @default(uuid())
  name      String         @default("My Wishlist")
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())

  @@index([userId])
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@unique([wishlistId, listingId])
  @@index([wishlistId])
  @@index([listingId])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  isRead     Boolean  @default(false)
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  listingId  String?
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      String?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}
